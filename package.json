      {
        "label": "Black Night",
        "uiTheme": "vs-dark",
        "path": "./themes/black-night.json"
      },
      {
        "label": "Black Mocha",
        "uiTheme": "vs-dark",
        "path": "./themes/black-mocha.json"
      },
      {
        "label": "Black Neon",
        "uiTheme": "vs-dark",
