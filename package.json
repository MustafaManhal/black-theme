{
  "name": "black-theme",
  "displayName": "Black Theme",
  "description": "8 pure black themes with vivid colors and visible borders",
  "version": "0.1.0",
  "publisher": "mustafamanhal",
  "repository": {
    "type": "git",
    "url": "https://github.com/MustafaManhall/black-theme"
