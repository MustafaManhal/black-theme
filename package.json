        "uiTheme": "vs-dark",
        "path": "./themes/black-borderless.json"
      },
      {
        "label": "Black Bordered Lite",
        "uiTheme": "vs-dark",
        "path": "./themes/black-bordered-lite.json"
      },
      {
        "label": "Black Bordered High Contrast",
        "uiTheme": "vs-dark",
        "path": "./themes/black-bordered-hc.json"
